# ── Optional upgrades — everything runs without these ─────────────────────────
# Cinematic Mapbox globe (3D dusk cities, atmosphere). Free tier: account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# Real concierge brain (Claude). Without it, a scripted offline concierge runs.
ANTHROPIC_API_KEY=

# Concierge model (default: claude-sonnet-5). Use claude-haiku-4-5-20251001 for snappier replies.
CONCIERGE_MODEL=
