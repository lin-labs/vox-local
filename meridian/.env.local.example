# ── Optional upgrades — everything runs without these ─────────────────────────
# Cinematic Mapbox globe (3D dusk cities, atmosphere). Free tier: account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# Realtime speech-to-speech concierge. Kept server-side; browsers receive only
# five-minute client secrets from /api/realtime-token.
XAI_API_KEY=

# Optional xAI voice settings.
XAI_VOICE_MODEL=grok-voice-think-fast-1.0
XAI_VOICE=eve

# Typed concierge brain (Claude agent loop with web search) — used when the
# realtime voice connection is unavailable. Without it, a scripted offline
# concierge runs.
ANTHROPIC_API_KEY=

# Concierge model (default: claude-sonnet-5). Use claude-haiku-4-5-20251001 for snappier replies.
CONCIERGE_MODEL=
